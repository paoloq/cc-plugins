{
  "item": "plugins/docs",
  "triggers": {
    "must_match_any": [
      "/docs:generate",
      "generate onboarding docs",
      "claude.md",
      "agent docs",
      "document this codebase for claude",
      "map this repo for claude"
    ],
    "positive": [
      "generate onboarding docs for this repo",
      "write a CLAUDE.md for this codebase",
      "add a CLAUDE.md to this repo",
      "create agent docs for /Users/me/proj",
      "document this codebase for Claude Code",
      "map this repo for Claude",
      "/docs:generate"
    ],
    "negative": [
      "review this pull request for security issues",
      "draft a spec for the new billing service",
      "write a prompt that drafts a weekly status report",
      "summarize what changed on this branch",
      "what does the Anthropic guide say about prompt caching?",
      "fix the failing test in tests/test_auth.py",
      "audit this repo and tell me where it falls short for coding agents"
    ]
  },
  "output": [
    {
      "id": "claude-plugin-manifest-present",
      "kind": "golden",
      "fixture": "../.claude-plugin/plugin.json",
      "must_contain": [
        "\"name\": \"docs\"",
        "/docs:generate"
      ]
    },
    {
      "id": "generate-skill-frontmatter",
      "kind": "golden",
      "fixture": "../skills/generate/SKILL.md",
      "frontmatter_required_keys": ["name", "description"],
      "must_contain": [
        "name: generate",
        "/docs:generate",
        "argument-hint:",
        "allowed-tools:"
      ]
    },
    {
      "id": "generate-skill-runs-signals",
      "kind": "golden",
      "fixture": "../skills/generate/SKILL.md",
      "must_contain": [
        "${CLAUDE_PLUGIN_ROOT}/skills/generate/scripts/signals.py",
        "Compose — bottom-up"
      ]
    },
    {
      "id": "generate-skill-hierarchical-claude-md",
      "kind": "golden",
      "fixture": "../skills/generate/SKILL.md",
      "must_contain": [
        "Per-area `CLAUDE.md`",
        "loading tiers",
        "on demand",
        "@`-import"
      ]
    },
    {
      "id": "generate-skill-lists-reference",
      "kind": "golden",
      "fixture": "../skills/generate/SKILL.md",
      "must_contain": [
        "references/output-spec.md",
        "## Additional Resources"
      ]
    },
    {
      "id": "generate-skill-imperative-opening",
      "kind": "golden",
      "fixture": "../skills/generate/SKILL.md",
      "regex_must_match": "^---[\\s\\S]+?---\\s*\\n+Generate Claude Code onboarding documentation",
      "must_not_contain": [
        "You are generating",
        "You read the code"
      ]
    },
    {
      "id": "output-spec-defines-marker-and-shapes",
      "kind": "golden",
      "fixture": "../skills/generate/references/output-spec.md",
      "must_contain": [
        "<!-- generated by docs:generate; safe to hand-edit; rerun overwrites -->",
        "Root `CLAUDE.md`",
        "Area `CLAUDE.md`",
        "Where to start",
        "earns_own_file",
        "architecture.md",
        "Re-run rules"
      ]
    },
    {
      "id": "signals-script-stdlib-only",
      "kind": "golden",
      "fixture": "../skills/generate/scripts/signals.py",
      "must_contain": [
        "Stdlib-only",
        "area_shape",
        "co_change",
        "ripple",
        "existing_outputs",
        "earns_own_file",
        "MARKER ="
      ],
      "regex_must_not_match": "^\\s*import\\s+(requests|httpx|yaml|toml|tomli)\\b"
    }
  ]
}
